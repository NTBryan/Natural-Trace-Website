<section class="hero">
  <div class="hero-bg" id="heroBg"></div>
  <div class="hero-overlay"></div>
  <div class="hero-visual"><img src="{{ home.hero_image }}" alt="{{ home.hero_image_alt }}" loading="eager"></div>
  <div class="hero-content">
    <div class="hero-badge"><span class="hero-badge-dot"></span>{{ home.hero_badge }}</div>
    <h1>
      <span class="hero-line"><span class="hero-line-inner">{{ home.hero_title_line1 }}</span></span>
      <span class="hero-line"><span class="hero-line-inner"><em>{{ home.hero_title_line2 }}</em></span></span>
    </h1>
    <p class="hero-slogan">{{ home.hero_slogan }}</p>
    <p class="hero-desc">{{ home.hero_desc }}</p>
    <div class="hero-actions">
      <a href="{{ home.hero_cta_url }}" class="btn btn-primary" style="cursor:pointer">{{ home.hero_cta }} &#8594;</a>
      <a href="{{ home.hero_cta_secondary_url }}" class="btn btn-outline" style="cursor:pointer">{{ home.hero_cta_secondary }}</a>
    </div>
    <div class="hero-stats">
      {% for stat in home.hero_stats %}
      <div class="hero-stat"><h3>{{ stat.title }}</h3><p>{{ stat.description }}</p></div>
      {% endfor %}
    </div>
  </div>
</section>

<div class="trust-bar">
  <div class="container">
    <div class="trust-bar-inner">
      <span class="trust-label">{{ home.trust_label }}</span>
      <div class="trust-logos">
        {% for logo in home.trust_logos %}
        <a class="trust-logo" href="{{ logo.url }}" target="_blank" rel="noopener"><img src="{{ logo.image }}" alt="{{ logo.alt }}"></a>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<section class="mission">
  <div class="container">
    <div style="text-align:center;margin-bottom:1rem">
      <span class="section-label anim anim-up">{{ home.mission_label }}</span>
      <h2 class="section-title anim anim-up delay-1">{{ home.mission_title }}</h2>
    </div>
    <div class="mission-grid">
      {% for card in home.mission_cards %}
      <div class="mission-card anim anim-up delay-{{ loop.index }}">
        <img class="mission-card-img" src="{{ card.image }}" alt="{{ card.alt }}" loading="lazy">
        <div class="mission-card-body">
          <h3>{{ card.title }}</h3>
          <p>{{ card.description }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>


<!-- Compatibility Quiz -->
<section class="compat-section">
  <div class="container">
    <div style="text-align:center;margin-bottom:2rem">
      <span class="section-label">{{ home.compat_label }}</span>
      <h2 class="section-title" style="color:#fff">{{ home.compat_title }}</h2>
      <p style="color:rgba(255,255,255,.6);max-width:600px;margin:0 auto">{{ home.compat_subtitle }}</p>
    </div>
    <div class="compat-quiz" id="compatQuiz">
      <!-- Progress bar -->
      <div class="compat-progress" id="compatProgress" style="display:none">
        <span class="compat-step-label" id="compatStepLabel">Step 1 of 3</span>
        <div class="compat-progress-bar"><div class="compat-progress-fill" id="compatProgressFill" style="width:33%"></div></div>
      </div>

      <!-- Welcome Screen -->
      <div class="compat-screen active" id="compatWelcome">
        <div class="compat-welcome">
          <svg width="64" height="64" viewBox="0 0 64 64" fill="none" style="margin-bottom:1rem"><circle cx="32" cy="32" r="30" stroke="var(--sage)" stroke-width="2.5" fill="rgba(107,114,73,.08)"/><path d="M22 32l6 6 14-14" stroke="var(--sage)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          <h3>{{ home.compat_welcome_title }}</h3>
          <p>{{ home.compat_welcome_desc }}</p>
          <button class="compat-cta" onclick="compatStart()">{{ home.compat_welcome_cta }}</button>
        </div>
      </div>

      <!-- Step 1: Product Category -->
      <div class="compat-screen" id="compatStep1">
        <p class="compat-q">{{ home.compat_step1_question }}</p>
        <div class="compat-grid" id="compatCategories"></div>
        <div class="compat-next-wrap" id="compatNext1">
          <button class="compat-next" onclick="compatGoStep(2)">{{ home.compat_btn_next }}</button>
        </div>
      </div>

      <!-- Step 2: Formulation -->
      <div class="compat-screen" id="compatStep2">
        <p class="compat-q">{{ home.compat_step2_question }}</p>
        <p style="color:var(--muted);font-size:.82rem;margin-top:-.75rem;margin-bottom:1rem">{{ home.compat_step2_hint }}</p>
        <div class="compat-grid compat-grid-3" id="compatFormulations"></div>
        <div class="compat-next-wrap" id="compatNext2">
          <button class="compat-back" onclick="compatGoStep(1)">{{ home.compat_btn_back }}</button>
          <button class="compat-next" onclick="compatGoStep(3)">{{ home.compat_btn_next }}</button>
        </div>
      </div>

      <!-- Step 3: Processing Conditions -->
      <div class="compat-screen" id="compatStep3">
        <p class="compat-q">{{ home.compat_step3_question }}</p>
        <div class="compat-conditions">
          <div class="compat-condition-group">
            <h4>{{ home.compat_step3_temp_label }}</h4>
            <div class="compat-condition-options" id="compatTempOptions"></div>
          </div>
          <div class="compat-condition-group">
            <h4>{{ home.compat_step3_ph_label }}</h4>
            <div class="compat-condition-options" id="compatPhOptions"></div>
          </div>
        </div>
        <div class="compat-next-wrap" id="compatNext3">
          <button class="compat-back" onclick="compatGoStep(2)">{{ home.compat_btn_back }}</button>
          <button class="compat-next" onclick="compatShowResult()">{{ home.compat_btn_results }}</button>
        </div>
      </div>

      <!-- Result Screen -->
      <div class="compat-screen" id="compatResult">
        <div class="compat-result">
          <div class="compat-score-wrap">
            <svg class="compat-score-svg" viewBox="0 0 180 180">
              <circle class="compat-score-bg" cx="90" cy="90" r="80"/>
              <circle class="compat-score-fill" id="compatScoreCircle" cx="90" cy="90" r="80" stroke="var(--sage)" stroke-dasharray="502.65" stroke-dashoffset="502.65"/>
            </svg>
            <div class="compat-score-num" id="compatScoreNum">0</div>
          </div>
          <div class="compat-verdict" id="compatVerdict"></div>
          <div class="compat-rec" id="compatRec"></div>
          <div class="compat-rec-card" id="compatRecCard">
            <h4 id="compatRecTitle"></h4>
            <p id="compatRecDesc"></p>
          </div>
          <div class="compat-actions" id="compatActions">
            <button class="compat-restart" onclick="compatReset()">{{ home.compat_result_restart }}</button>
            <button class="compat-cta" href="{{ home.compat_result_cta_url }}" style="font-size:.85rem;padding:.7rem 1.5rem">{{ home.compat_result_cta }}</button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
