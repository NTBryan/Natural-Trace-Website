<!-- FAQ Schema.org Structured Data for SEO -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for q in faq.questions %}
    {"@type":"Question","name":{{ q.question | dump | safe }},"acceptedAnswer":{"@type":"Answer","text":{{ q.answer | dump | safe }}}}{% if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>
