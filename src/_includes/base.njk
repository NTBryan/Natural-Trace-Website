<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if title %}{{ title }} | {% endif %}Natural Trace — Tag. Trace. Trust.</title>
<link rel="icon" type="image/png" href="/assets/logos/NT icon without logo.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600;700;800;900&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/assets/css/styles.css">
</head>
<body{% if permalink == "/" or permalink == "/home/" %} class="splash-active"{% endif %}>

{% if permalink == "/" or permalink == "/home/" %}
{% include "partials/splash.njk" %}
{% endif %}

{% include "partials/nav.njk" %}

<main>
  {{ content | safe }}
</main>

{% include "partials/footer.njk" %}

{% if permalink == "/faq/" %}
{% include "partials/faq-schema.njk" %}
{% endif %}

<script src="/assets/js/main.js"></script>
</body>
</html>
