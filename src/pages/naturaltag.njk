<!-- How It Works — pipeline step grid, sage olive bg -->
<section class="nt-pipeline pipeline">
  <div class="container">
    <div class="pipeline-header">
      <span class="section-label anim anim-up">How It Works</span>
      <h2 class="section-title anim anim-up delay-1" style="color:#fff">From Source to Certainty</h2>
    </div>
    <div class="pipeline-steps" style="grid-template-columns:repeat(3,1fr)">
      <div class="pipeline-step anim anim-up delay-1">
        <div class="pipeline-step-num">01</div>
        <h3>Formulate</h3>
        <p>NaturalTag&trade; is formulated directly into your product during manufacturing. A blend of inactivated probiotic markers integrated at source. No process changes required.</p>
      </div>
      <div class="pipeline-step anim anim-up delay-2">
        <div class="pipeline-step-num">02</div>
        <h3>Embed</h3>
        <p>The molecular marker becomes part of the product matrix. It survives processing, storage, and transport. The tag cannot be removed, transferred, or counterfeited.</p>
      </div>
      <div class="pipeline-step anim anim-up delay-3">
        <div class="pipeline-step-num">03</div>
        <h3>Verify</h3>
        <p>At any point downstream, a sample is tested with NaturalDetect&trade; to confirm origin and authenticity. The tag is the proof.</p>
      </div>
    </div>
  </div>
</section>

