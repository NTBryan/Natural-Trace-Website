---
layout: base.njk
title: "Team"
permalink: /team/
---

<section class="privacy-page" style="background:var(--offwhite)">
  <div class="container">
    <a class="privacy-back" href="/about/">&#8592; Back to About</a>
    <div style="text-align:center;margin-bottom:3rem">
      <span class="section-label">The People Behind Natural Trace</span>
      <h2 class="section-title">Our Team</h2>
    </div>
    <div class="team-grid">
      {% for member in team.members %}{% if member.type == "leadership" %}
      <div class="team-card" onclick="openTeamModal({{ loop.index0 }})" style="cursor:pointer">
        <div class="team-avatar"><img src="{{ member.photo }}" alt="{{ member.name }}"></div>
        <div class="team-card-info">
          <h4>{{ member.name }}</h4>
          <p class="team-role">{{ member.role }}</p>
          <p class="team-loc">{{ member.location }}</p>
        </div>
      </div>
      {% endif %}{% endfor %}
    </div>

    <div style="text-align:center;margin:4rem 0 2rem">
      <span class="section-label">Guidance &amp; Expertise</span>
      <h2 class="section-title" style="font-size:clamp(1.6rem,3vw,2.2rem)">Advisors</h2>
    </div>
    <div class="team-grid advisor-grid">
      {% for member in team.members %}{% if member.type == "advisor" %}
      <div class="team-card" onclick="openTeamModal({{ loop.index0 }})" style="cursor:pointer">
        <div class="team-avatar"><img src="{{ member.photo }}" alt="{{ member.name }}"></div>
        <div class="team-card-info">
          <h4>{{ member.name }}</h4>
          <p class="team-role">{{ member.role }}</p>
        </div>
      </div>
      {% endif %}{% endfor %}
    </div>
  </div>
</section>

<!-- Team Modal -->
<div class="team-modal-overlay" id="teamModal">
  <div class="team-modal">
    <div class="team-modal-photo"><img id="modalPhoto" src="" alt=""></div>
    <div class="team-modal-body">
      <button class="team-modal-close" onclick="closeTeamModal()">&times;</button>
      <h3 id="modalName"></h3>
      <p class="tm-role" id="modalRole"></p>
      <p class="tm-loc" id="modalLoc"></p>
      <div class="tm-edu" id="modalEdu"></div>
      <ul class="tm-bio" id="modalBio"></ul>
      <a class="team-modal-linkedin" id="modalLinkedin" href="" target="_blank" rel="noopener" title="LinkedIn">in</a>
    </div>
  </div>
</div>

<script>
var teamData = {{ team.members | dump | safe }};
</script>
