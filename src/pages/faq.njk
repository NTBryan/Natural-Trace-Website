---
layout: base.njk
title: "Faq"
permalink: /faq/
---

<section class="faq-page-hero">
  <div class="container">
    <span class="section-label" style="color:var(--sage-light)">{{ faq.section_label }}</span>
    <h1>{{ faq.title }}</h1>
    <p>{{ faq.subtitle }}</p>
  </div>
</section>
<section class="faq-section">
  <div class="container">
    <div class="faq-categories" id="faqCats">
      <button class="faq-cat-btn active" onclick="filterFaq('all')">All</button>
      {% for cat in faq.categories %}
      <button class="faq-cat-btn" onclick="filterFaq('{{ cat.id }}')">{{ cat.label }}</button>
      {% endfor %}
    </div>
    <div class="faq-grid" id="faqGrid">

      {% for q in faq.questions %}
      <div class="faq-item" data-cat="{{ q.category }}">
        <button class="faq-question" onclick="toggleFaqItem(this)">
          <span>{{ q.question }}</span>
          <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="faq-answer"><div class="faq-answer-inner">{{ q.answer }}</div></div>
      </div>
      {% endfor %}

    </div>
  </div>
</section>
<section class="faq-cta-bar">
  <div class="container">
    <h2>{{ faq.cta_title }}</h2>
    <p>{{ faq.cta_text }}</p>
    <a href="/contact/" class="btn btn-primary" style="cursor:pointer">Get in Touch &#8594;</a>
  </div>
</section>
</div>
