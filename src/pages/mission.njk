---
layout: base.njk
title: "Mission & Values"
permalink: /mission/
---

{# ── Hero Banner ── #}
<section style="background:var(--dark);padding:8rem 0 4rem;position:relative;overflow:hidden">
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(107,114,73,.4) 0%,rgba(26,30,46,.95) 100%)"></div>
  <div class="container" style="position:relative;z-index:1;text-align:center;max-width:800px">
    <span class="section-label anim anim-up" style="color:rgba(255,255,255,.7)">{{ mission.label }}</span>
    <h1 class="section-title anim anim-up delay-1" style="color:#fff;font-size:2.8rem;margin-bottom:1.25rem">{{ mission.title }}</h1>
    <p class="anim anim-up delay-2" style="font-size:1.1rem;color:rgba(255,255,255,.7);line-height:1.8">{{ mission.hero_subtitle }}</p>
  </div>
</section>

{# ── The Problem ── #}
<section style="padding:5rem 0;background:#fff">
  <div class="container" style="max-width:820px">
    <div class="anim anim-up" style="text-align:center;margin-bottom:2.5rem">
      <span class="section-label">{{ mission.problem_label }}</span>
      <h2 class="section-title">{{ mission.problem_title }}</h2>
    </div>
    <div class="anim anim-up delay-1">
      <p style="font-size:1.02rem;color:var(--muted);line-height:1.9;margin-bottom:1.5rem">{{ mission.problem_text }}</p>
      <p style="font-size:1.02rem;color:var(--muted);line-height:1.9">{{ mission.problem_text_2 }}</p>
    </div>
  </div>
</section>

{# ── Mission Statement + Founding Quote ── #}
<section style="padding:5rem 0;background:var(--offwhite)">
  <div class="container" style="max-width:820px">
    <div style="text-align:center;margin-bottom:3rem" class="anim anim-up">
      <span class="section-label">{{ mission.mission_label }}</span>
      <h2 class="section-title" style="margin-bottom:1.5rem">{{ mission.mission_title }}</h2>
      <p style="font-size:1.05rem;color:var(--muted);line-height:1.8;max-width:720px;margin:0 auto">{{ mission.mission_text }}</p>
    </div>

    {# Pull quote #}
    <div class="anim anim-up delay-1" style="border-left:3px solid var(--sage);padding:1.5rem 2rem;margin:2.5rem auto;max-width:680px;background:rgba(107,114,73,.04);border-radius:0 12px 12px 0">
      <p style="font-size:1.05rem;font-style:italic;color:var(--dark);line-height:1.8;margin:0">{{ mission.founding_quote }}</p>
    </div>
  </div>
</section>

{# ── Values ── #}
<section style="padding:5rem 0;background:#fff">
  <div class="container" style="max-width:960px">
    <div style="text-align:center;margin-bottom:2.5rem" class="anim anim-up">
      <span class="section-label">{{ mission.values_label }}</span>
      <h2 class="section-title">{{ mission.values_title }}</h2>
    </div>

    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-bottom:4rem" class="mission-values-grid">
      {% for value in mission.values %}
      <div class="anim" style="background:var(--offwhite);border-radius:16px;padding:2rem;border:1px solid #E5E7EB;transition:transform .4s,box-shadow .4s;text-align:center">
        <div style="width:48px;height:48px;border-radius:12px;background:var(--sage);display:inline-flex;align-items:center;justify-content:center;margin-bottom:1.25rem;margin-left:auto;margin-right:auto">
          {% if value.icon == "microscope" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 18h8"/><path d="M3 22h18"/><path d="M14 22a7 7 0 1 0 0-14h-1"/><path d="M9 14h2"/><path d="M9 12a2 2 0 0 1-2-2V6h6v4a2 2 0 0 1-2 2Z"/><path d="M12 6V3a1 1 0 0 0-1-1H9a1 1 0 0 0-1 1v3"/></svg>
          {% elif value.icon == "eye" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"/><circle cx="12" cy="12" r="3"/></svg>
          {% elif value.icon == "shield" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          {% elif value.icon == "handshake" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m11 17 2 2a1 1 0 1 0 3-3"/><path d="m14 14 2.5 2.5a1 1 0 1 0 3-3l-3.88-3.88a3 3 0 0 0-4.24 0l-.88.88a1 1 0 1 1-3-3l2.81-2.81a5.79 5.79 0 0 1 7.06-.87l.47.28a2 2 0 0 0 1.42.25L21 4"/><path d="m21 3 1 11h-2"/><path d="M3 3 2 14h2"/><path d="m7 4 3.22 3.22"/><path d="m8 12 3-3"/></svg>
          {% elif value.icon == "document" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
          {% elif value.icon == "chart" %}
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v16a2 2 0 0 0 2 2h16"/><path d="m19 9-5 5-4-4-3 3"/></svg>
          {% endif %}
        </div>
        <h3 style="font-family:'Bebas Neue','Inter',sans-serif;font-size:1.15rem;color:var(--dark);margin-bottom:.5rem">{{ value.title }}</h3>
        <p style="font-size:.88rem;color:var(--muted);line-height:1.7">{{ value.description }}</p>
      </div>
      {% endfor %}
    </div>

    {# CTA #}
    <div style="text-align:center;padding:3rem 2rem;background:var(--offwhite);border-radius:16px;border:1px solid #E5E7EB" class="anim">
      <p style="font-size:1.05rem;color:var(--muted);margin-bottom:1.5rem">{{ mission.cta_text }}</p>
      <a href="{{ mission.cta_button_url }}" class="btn" style="cursor:pointer;background:var(--sage);color:#fff">{{ mission.cta_button_text }}</a>
    </div>
  </div>
</section>
