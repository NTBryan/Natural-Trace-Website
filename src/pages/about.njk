---
layout: base.njk
title: "About"
permalink: /about/
---

<section class="about" id="story">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-wrapper anim anim-right">
        <img src="data:image/jpeg;base64," alt="{{ about.hero_image_alt }}" loading="lazy">
        <div class="about-accent"></div>
      </div>
      <div class="about-text">
        <span class="section-label anim anim-up">{{ about.label }}</span>
        <h2 class="section-title anim anim-up delay-1">{{ about.title }}</h2>
        <p class="section-subtitle anim anim-up delay-2">{{ about.intro }}</p>
        <div class="about-highlights anim anim-up delay-3">
          {% for highlight in about.highlights %}
          <div class="about-highlight"><div><h4>{{ highlight.title }}</h4><p>{{ highlight.description }}</p></div></div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="mission">
  <div class="container">
    <div style="text-align:center;margin-bottom:1rem">
      <span class="section-label anim anim-up">{{ about.approach_label }}</span>
      <h2 class="section-title anim anim-up delay-1">{{ about.approach_title }}</h2>
      <p class="section-subtitle anim anim-up delay-2" style="margin:0 auto">{{ about.approach_subtitle }}</p>
    </div>
    <div class="mission-grid" style="margin-top:3rem">
      {% for value in about.values %}
      <div class="mission-card anim anim-up delay-{{ loop.index }}">
        <img class="mission-card-img" src="{{ value.image }}" alt="{{ value.image_alt }}" loading="lazy">
        <div class="mission-card-body">
          <h3>{{ value.title }}</h3>
          <p>{{ value.description | safe }}</p>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
</div>

