---
layout: base.njk
title: "Contact"
summary: "Get in touch with Natural Trace to discuss a compatibility project, schedule a consultation, or learn about our molecular traceability platform."
permalink: /contact/
---

<section class="contact-section">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-label anim anim-up">{{ contact.section_label }}</span>
        <h2 class="section-title anim anim-up delay-1">{{ contact.title }}</h2>
        <p class="section-subtitle anim anim-up delay-2" style="margin-bottom:2.5rem">{{ contact.subtitle | safe }}</p>

        {% for item in contact.info_items %}
        <div class="contact-info-item anim anim-up delay-{{ loop.index + 1 }}">
          <div class="contact-info-item-dot"></div>
          <div><h4>{{ item.label }}</h4><p>{{ item.description | safe }}</p></div>
        </div>
        {% endfor %}
      </div>
      <div class="contact-form anim anim-left delay-2">
        <h3>{{ contact.form.title }}</h3>
        <p>{{ contact.form.subtitle }}</p>
        <form id="contactForm" onsubmit="return handleContactSubmit(event)">
          <div class="form-row">
            <div class="form-group">
              <label>{{ contact.form.first_name_label }}</label>
              <input type="text" name="firstName" required placeholder="{{ contact.form.first_name_placeholder }}">
            </div>
            <div class="form-group">
              <label>{{ contact.form.last_name_label }}</label>
              <input type="text" name="lastName" required placeholder="{{ contact.form.last_name_placeholder }}">
            </div>
          </div>
          <div class="form-group">
            <label>{{ contact.form.email_label }}</label>
            <input type="email" name="email" required placeholder="{{ contact.form.email_placeholder }}">
          </div>
          <div class="form-group">
            <label>{{ contact.form.company_label }}</label>
            <input type="text" name="company" placeholder="{{ contact.form.company_placeholder }}">
          </div>
          <div class="form-group">
            <label>{{ contact.form.inquiry_type_label }}</label>
            <select name="inquiryType" required>
              <option value="" disabled selected>{{ contact.form.inquiry_type_placeholder }}</option>
              {% for type in contact.inquiry_types %}
              <option value="{{ type.value }}">{{ type.label | safe }}</option>
              {% endfor %}
            </select>
          </div>
          <div class="form-group">
            <label>{{ contact.form.message_label }}</label>
            <textarea name="message" required placeholder="{{ contact.form.message_placeholder }}"></textarea>
          </div>
          <button type="submit" class="form-submit">{{ contact.form.submit_text }}</button>
        </form>
        <div class="form-success" id="formSuccess">
          <h4>{{ contact.success.title }}</h4>
          <p>{{ contact.success.message }}</p>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="cta-shape cta-shape-1"></div>
  <div class="cta-shape cta-shape-2"></div>
  <div class="container">
    <div class="cta-inner">
      <span class="section-label anim anim-up">{{ contact.cta.section_label }}</span>
      <h2 class="anim anim-up delay-1">{{ contact.cta.title }}</h2>
      <p class="anim anim-up delay-2">{{ contact.cta.subtitle }}</p>
      <div class="cta-actions anim anim-up delay-3">
        <a href="{{ contact.cta.primary_href }}" class="btn btn-white">{{ contact.cta.primary_text | safe }}</a>
        <a href="{{ contact.cta.secondary_href }}" class="btn btn-ghost" style="cursor:pointer">{{ contact.cta.secondary_text }}</a>
      </div>
    </div>
  </div>
</section>
</div>

