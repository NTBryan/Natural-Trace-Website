---
layout: base.njk
title: "Industries"
permalink: /industries/
---

<section class="industries">
  <div class="container">
    <div class="industries-header">
      <span class="section-label anim anim-up">{{ industries.label }}</span>
      <h2 class="section-title anim anim-up delay-1">{{ industries.title }}</h2>
      <p class="section-subtitle anim anim-up delay-2">{{ industries.subtitle }}</p>
    </div>
    <div class="industries-grid">
      {% for industry in industries.industries %}
      <div class="industry-card anim anim-scale delay-{{ loop.index }}">
        <img src="{{ industry.image }}" alt="{{ industry.image_alt }}" loading="lazy">
        <div class="industry-card-overlay"><h3>{{ industry.name }}</h3><p>{{ industry.description }}</p></div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="cta-section">
  <div class="cta-bg"></div>
  <div class="cta-shape cta-shape-1"></div>
  <div class="cta-shape cta-shape-2"></div>
  <div class="container">
    <div class="cta-inner">
      <span class="section-label anim anim-up">{{ industries.cta_label }}</span>
      <h2 class="anim anim-up delay-1">{{ industries.cta_title }}</h2>
      <p class="anim anim-up delay-2">{{ industries.cta_description }}</p>
      <div class="cta-actions anim anim-up delay-3">
        <a href="{{ industries.cta_button_primary_url }}" class="btn btn-white" style="cursor:pointer">{{ industries.cta_button_primary_text }} &#8594;</a>
        <a href="{{ industries.cta_button_secondary_url }}" class="btn btn-ghost" style="cursor:pointer">{{ industries.cta_button_secondary_text }}</a>
      </div>
    </div>
  </div>
</section>
</div>

